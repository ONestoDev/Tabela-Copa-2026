rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();

      match /seasons/{seasonId} {
        allow read: if true;
        allow write: if isAdmin();

        match /official/state {
          allow read: if true;
          allow write: if isAdmin();
        }

        match /predictions/{userId} {
          allow read: if true;
          allow create, update, delete: if signedIn() && request.auth.uid == userId;
        }

        match /users/{userId} {
          allow read: if true;
          allow create, update: if signedIn() && request.auth.uid == userId;
          allow delete: if isAdmin() || (signedIn() && request.auth.uid == userId);
        }

        match /leaderboards/{leaderboardId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }
  }
}
